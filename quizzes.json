[{
  "_id": {
    "$oid": "6a33f8beb0c06d01d25388dc"
  },
  "quizCode": "Q1.1",
  "title": "Module 1.1 – Introduction to ICT",
  "moduleId": "MODULE_1_1",
  "bundleTopic": "Lesson 1: Information and Communication Technology",
  "questions": [
    {
      "text": "What is data?",
      "options": [
        "Processed information",
        "Raw facts and figures",
        "Knowledge",
        "Report"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388dd"
      }
    },
    {
      "text": "Which of the following is data?",
      "options": [
        "Student report",
        "85, 90, 75",
        "Annual summary",
        "Result sheet"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388de"
      }
    },
    {
      "text": "Information is obtained by:",
      "options": [
        "Storing data",
        "Processing data",
        "Deleting data",
        "Sharing data"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388df"
      }
    },
    {
      "text": "Which characteristic means information is correct?",
      "options": [
        "Timeliness",
        "Accuracy",
        "Cost",
        "Relevance"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e0"
      }
    },
    {
      "text": "Which of the following is information?",
      "options": [
        "Marks entered into a system",
        "Student attendance numbers",
        "Average class mark report",
        "Raw survey answers"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e1"
      }
    },
    {
      "text": "Data can be represented using:",
      "options": [
        "Numbers",
        "Text",
        "Images",
        "All of the above"
      ],
      "correctOption": 3,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e2"
      }
    },
    {
      "text": "The main purpose of information is:",
      "options": [
        "Entertainment",
        "Decision making",
        "Programming",
        "Storage"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e3"
      }
    },
    {
      "text": "Raw facts are known as:",
      "options": [
        "Information",
        "Knowledge",
        "Data",
        "Reports"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e4"
      }
    },
    {
      "text": "A weather report is:",
      "options": [
        "Data",
        "Information",
        "Program",
        "Input"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e5"
      }
    },
    {
      "text": "Which one is NOT information?",
      "options": [
        "Monthly sales report",
        "Student performance summary",
        "Profit analysis",
        "List of marks before calculation"
      ],
      "correctOption": 3,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e6"
      }
    },
    {
      "text": "What converts data into information?",
      "options": [
        "Input",
        "Processing",
        "Storage",
        "Output"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e7"
      }
    },
    {
      "text": "Which characteristic ensures information contains all required details?",
      "options": [
        "Accuracy",
        "Timeliness",
        "Completeness",
        "Relevance"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e8"
      }
    },
    {
      "text": "Why is timely information important?",
      "options": [
        "Reduces storage",
        "Helps current decision making",
        "Increases speed",
        "Saves electricity"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388e9"
      }
    },
    {
      "text": "A student’s final report card is:",
      "options": [
        "Data",
        "Information",
        "Instruction",
        "Program"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388ea"
      }
    },
    {
      "text": "Which of the following best represents processing?",
      "options": [
        "Entering exam marks",
        "Calculating class average",
        "Printing marks",
        "Saving a file"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388eb"
      }
    },
    {
      "text": "Information that is unrelated to a task lacks:",
      "options": [
        "Accuracy",
        "Completeness",
        "Relevance",
        "Timeliness"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388ec"
      }
    },
    {
      "text": "A company manager uses information mainly to:",
      "options": [
        "Increase storage",
        "Make decisions",
        "Upgrade hardware",
        "Create software"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388ed"
      }
    },
    {
      "text": "Which characteristic of information reduces the chance of incorrect decisions?",
      "options": [
        "Accuracy",
        "Size",
        "Color",
        "Format"
      ],
      "correctOption": 0,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388ee"
      }
    },
    {
      "text": "A list of temperatures recorded every hour is:",
      "options": [
        "Information",
        "Data",
        "Knowledge",
        "Report"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388ef"
      }
    },
    {
      "text": "Which statement is true?",
      "options": [
        "Data is always meaningful",
        "Information is always raw",
        "Information results from processing data",
        "Information cannot be stored"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f0"
      }
    },
    {
      "text": "A school collects student marks and calculates the pass percentage. The pass percentage is:",
      "options": [
        "Data",
        "Input",
        "Information",
        "Storage"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f1"
      }
    },
    {
      "text": "Which characteristic is most important when using information for emergency medical decisions?",
      "options": [
        "Color",
        "Timeliness",
        "Format",
        "Size"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f2"
      }
    },
    {
      "text": "A company receives 10,000 sales records. After analysis, management receives a sales trend report. The report is:",
      "options": [
        "Data",
        "Information",
        "Input device",
        "Program"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f3"
      }
    },
    {
      "text": "Which combination represents good quality information?",
      "options": [
        "Accurate, Complete, Relevant",
        "Large, Colorful, Detailed",
        "Fast, Cheap, Large",
        "Complex, Technical, Long"
      ],
      "correctOption": 0,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f4"
      }
    },
    {
      "text": "Which scenario demonstrates the transformation of data into information?",
      "options": [
        "Entering marks into a database",
        "Printing blank forms",
        "Generating student rankings from marks",
        "Saving records"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f5"
      }
    },
    {
      "text": "Why might incomplete information be dangerous?",
      "options": [
        "Uses more storage",
        "Leads to poor decisions",
        "Slows the computer",
        "Increases memory usage"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f6"
      }
    },
    {
      "text": "A business analyst uses customer purchase records to identify buying patterns. The identified patterns are:",
      "options": [
        "Data",
        "Information",
        "Hardware",
        "Input"
      ],
      "correctOption": 1,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f7"
      }
    },
    {
      "text": "Which of the following is the best example of relevant information?",
      "options": [
        "Weather data for another country",
        "Student marks from last decade",
        "Current semester performance report",
        "Old attendance records"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f8"
      }
    },
    {
      "text": "The quality of information depends on:",
      "options": [
        "Processing and accuracy of data",
        "Screen size",
        "Printer type",
        "Internet speed only"
      ],
      "correctOption": 0,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388f9"
      }
    },
    {
      "text": "A hospital system records patient temperatures every hour. The temperature readings are data, while the diagnosis generated from them is:",
      "options": [
        "Storage",
        "Data",
        "Information",
        "Input"
      ],
      "correctOption": 2,
      "_id": {
        "$oid": "6a33f8beb0c06d01d25388fa"
      }
    }
  ],
